# Server Environment Config
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=*

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/recruitment_db?retryWrites=true&w=majority

# JSON Web Token Secret
JWT_SECRET=ism_data_technology_recruitment_secret_2026_jwt_token_key

# Cloudinary Storage Configurations
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Configuration (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=careers@ismdatatechnology.com
ADMIN_NOTIFICATION_EMAIL=admin@ismdatatechnology.com

